{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MajorDream444/client-clarity-intake-os/schemas/extraction/blueprint-output.schema.json",
  "title": "Client Clarity Blueprint Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "founder_profile",
    "doctrine_map",
    "core_icp",
    "secondary_icp",
    "current_revenue_proof",
    "strongest_offer",
    "offer_ladder",
    "lead_flow_diagnosis",
    "conversion_diagnosis",
    "biggest_revenue_leak",
    "resistance_patterns",
    "assets_available",
    "assets_missing",
    "recommended_first_build",
    "thirty_day_plan",
    "proposal_angle",
    "operator_notes"
  ],
  "properties": {
    "founder_profile": { "type": "string" },
    "doctrine_map": { "type": "string" },
    "core_icp": { "type": "string" },
    "secondary_icp": { "type": "string" },
    "current_revenue_proof": { "type": "string" },
    "strongest_offer": { "type": "string" },
    "offer_ladder": { "type": "array", "items": { "type": "string" } },
    "lead_flow_diagnosis": { "type": "string" },
    "conversion_diagnosis": { "type": "string" },
    "biggest_revenue_leak": { "type": "string" },
    "resistance_patterns": { "type": "string" },
    "assets_available": { "type": "array", "items": { "type": "string" } },
    "assets_missing": { "type": "array", "items": { "type": "string" } },
    "recommended_first_build": { "type": "string" },
    "thirty_day_plan": { "type": "array", "items": { "type": "string" } },
    "proposal_angle": { "type": "string" },
    "operator_notes": { "type": "string" }
  }
}
