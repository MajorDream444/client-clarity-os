    { "name": "Client Email", "type": "email" },
    { "name": "WhatsApp", "type": "phone_number" },
    { "name": "Origin", "type": "rich_text" },
    { "name": "Work / Authority", "type": "rich_text" },
    { "name": "People / ICP", "type": "rich_text" },
    { "name": "Offer / Revenue", "type": "rich_text" },
    { "name": "Resistance / Boundaries", "type": "rich_text" },
    { "name": "Expression / Delivery", "type": "rich_text" },
    { "name": "Vision", "type": "rich_text" },
    { "name": "Reality Check", "type": "rich_text" },
    { "name": "Final Reflection", "type": "rich_text" },
    { "name": "Asset Links", "type": "rich_text" },
    { "name": "Drive / Data Room URL", "type": "url" },
